{
  "name": "ai4health",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/*",
      "destination": "http://129.211.228.122/api/:splat"
    },
    {
      "source": "/health",
      "destination": "http://129.211.228.122/health"
    }
  ],
  "headers": [
    {
      "source": "/js/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=300"
        }
      ]
    },
    {
      "source": "/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=60"
        }
      ]
    }
  ]
}
